# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored and must NEVER be committed or shared.

# --- Required for the main study ---
# OpenRouter: used for GLM-4.7 (pinned to the Cerebras backend) and the gpt-4.1-mini monitor.
# Needs a paid key with credit (the routing in exp/common.py expects no rate-limit cap).
OPENROUTER_API_KEY=sk-or-v1-...
# Together AI: used for gpt-oss-120b.
TOGETHER_API_KEY=...

# --- Optional: Azure (summarized-CoT cross-check only; not used by the main study) ---
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
